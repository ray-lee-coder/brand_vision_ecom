#!/usr/bin/env bash
# BrandKit CLI — 统一入口 (v0.3.0-alpha)
set -euo pipefail

BRANDKIT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
cd "$BRANDKIT_DIR"

CMD="${1:-help}"
shift || true

OFFLINE=""
ALLOW_WARNINGS=""
ALLOW_PLACEHOLDER=""

# Parse global flags
for arg in "$@"; do
  case "$arg" in
    --offline) OFFLINE="--dry-run" ; set -- "${@/--offline/}" ;;
    --allow-warnings) ALLOW_WARNINGS="--allow-warnings" ; set -- "${@/--allow-warnings/}" ;;
    --allow-placeholder) ALLOW_PLACEHOLDER="--allow-placeholder" ; set -- "${@/--allow-placeholder/}" ;;
  esac
done

case "$CMD" in
  init)
    BRAND="${1:-}"
    if [ -z "$BRAND" ]; then
      echo "Usage: brandkit init <brand-name>"
      exit 1
    fi
    mkdir -p "brands/$BRAND/products" "brands/$BRAND/assets"
    echo "[OK] Initialized brand: $BRAND"
    ;;

  build)
    CAMPAIGN="${1:-campaigns/618-launch.yaml}"
    CAMPAIGN_NAME="$(basename "$CAMPAIGN" .yaml)"

    echo "[BUILD] Compiling specs from: $CAMPAIGN"
    python3 scripts/compile.py "$CAMPAIGN"

    echo "[BUILD] Rendering visual... ($([ -n "$OFFLINE" ] && echo 'placeholder' || echo 'full'))"
    python3 scripts/render_visual.py $ALLOW_PLACEHOLDER $([ -n "$OFFLINE" ] && echo '--placeholder')
    VISUAL_EXIT=$?
    if [ $VISUAL_EXIT -ne 0 ]; then
      echo "[FAIL] Visual render failed"
      exit $VISUAL_EXIT
    fi

    echo "[BUILD] Rendering content... ($([ -n "$OFFLINE" ] && echo 'offline' || echo 'full'))"
    python3 scripts/render_content.py $OFFLINE
    CONTENT_EXIT=$?
    if [ $CONTENT_EXIT -ne 0 ]; then
      echo "[FAIL] Content render failed"
      exit $CONTENT_EXIT
    fi

    echo "[BUILD] Verifying..."
    python3 scripts/verify.py $ALLOW_WARNINGS
    VERIFY_EXIT=$?
    if [ $VERIFY_EXIT -ne 0 ] && [ -z "$ALLOW_WARNINGS" ]; then
      echo "[FAIL] Verification failed (use --allow-warnings to override)"
      exit $VERIFY_EXIT
    fi

    echo "[BUILD] Validating channels..."
    python3 scripts/validate_channel.py $ALLOW_WARNINGS
    VALIDATE_EXIT=$?
    if [ $VALIDATE_EXIT -ne 0 ] && [ -z "$ALLOW_WARNINGS" ]; then
      echo "[FAIL] Channel validation failed (use --allow-warnings to override)"
      exit $VALIDATE_EXIT
    fi

    echo ""
    echo "[DONE] Build complete. Output in output/$CAMPAIGN_NAME/"
    ;;

  build-all)
    echo "[BUILD-ALL] Building all campaigns... (real gen mode)"
    for f in campaigns/*.yaml; do
      echo ""
      echo "=== $(basename "$f") ==="
      bash "$0" build "$f" $OFFLINE $ALLOW_WARNINGS $ALLOW_PLACEHOLDER || echo "[WARN] Build failed for $f"
    done
    echo ""
    echo "[DONE] All campaigns built."
    ;;

  render)
    SUB="${1:-visual}"
    shift 2>/dev/null || true
    case "$SUB" in
      visual) python3 scripts/render_visual.py "$@" ;;
      content) python3 scripts/render_content.py "$@" ;;
      ab) python3 scripts/ab_generator.py "$@" ;;
      *) echo "Usage: brandkit render <visual|content|ab> [options]" ;;
    esac
    ;;

  verify)
    python3 scripts/verify.py "$@"
    ;;

  validate)
    python3 scripts/validate_channel.py "$@"
    ;;

  baseline)
    CAMPAIGN="${1:-campaigns/618-launch.yaml}"
    echo "[BASELINE] Running pure-prompt baseline for: $CAMPAIGN"
    python3 scripts/run_baseline.py "$CAMPAIGN" --dry-run "$@"
    ;;

  ab)
    echo "[AB] Generating A/B drafts..."
    python3 scripts/ab_generator.py --resolved .build/resolved-task.json --message-plan .build/message-plan.json --dry-run "$@"
    ;;

  clean)
    rm -rf .build output
    echo "[OK] Cleaned .build/ and output/"
    ;;

  help|*)
    echo "BrandKit v0.3.0-alpha — 品牌约束视觉与内容编译器"
    echo ""
    echo "Usage:"
    echo "  brandkit build [campaign]         Build campaign (default: real gen)"
    echo "    --offline                       Use template fallback instead of LLM"
    echo "    --allow-warnings                Don't fail on validation warnings"
    echo "    --allow-placeholder             Allow placeholder product images"
    echo "  brandkit build-all                 Build all campaigns"
    echo "  brandkit render <visual|content|ab>"
    echo "  brandkit verify [--allow-warnings]"
    echo "  brandkit validate [--allow-warnings]"
    echo "  brandkit baseline [campaign]       Pure-prompt baseline comparison"
    echo "  brandkit clean                     Clean build/ and output/"
    echo ""
    echo "Default mode (no flags): real LLM gen, all verification blocks on failure."
    echo "Use --offline for dev/testing without API calls."
    ;;
esac