{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Campaign Schema v1",
  "description": "Campaign task entry — selects brand, product, channels, outputs",
  "type": "object",
  "properties": {
    "campaign": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "brand_ref": { "type": "string", "minLength": 1 },
        "product_ref": { "type": "string", "minLength": 1 },
        "objective": { "type": "string" },
        "audience": { "type": "string" }
      },
      "required": ["name", "brand_ref", "product_ref"]
    },
    "outputs": {
      "type": "object",
      "properties": {
        "visual": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "channel": { "type": "string" },
              "format": { "type": "string" }
            },
            "required": ["type", "channel"]
          }
        },
        "content": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "channel": { "type": "string" }
            },
            "required": ["type", "channel"]
          }
        }
      },
      "anyOf": [
        { "required": ["visual"] },
        { "required": ["content"] }
      ]
    },
    "override": {
      "type": "object",
      "properties": {
        "headline_max_chars": { "type": "integer" },
        "headline_max_lines": { "type": "integer" },
        "safe_margin_px": { "type": "integer" },
        "product_title_max_chars": { "type": "integer" },
        "bullet_count": { "type": "integer" },
        "bullet_max_chars_each": { "type": "integer" }
      },
      "additionalProperties": false
    }
  },
  "required": ["campaign", "outputs"],
  "additionalProperties": false
}